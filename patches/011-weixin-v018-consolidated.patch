+class ReplyBudgetStore:
+    # WECHAT_ENHANCE_REPLY_BUDGET_COMMIT_AFTER_ACK_V2
+    # HERMES_WECHAT_CONTEXT_TOKEN_GENERATION_FENCE_V1
+    # HERMES_WECHAT_CONTEXT_BUDGET_RECONCILIATION_V1
+    _TOKEN_TTL_SECONDS: float = 24 * 3600.0
+    _MAX_BUBBLES_PER_TOKEN: int = 10
+
+    def __init__(self, hermes_home: str):
+        self._root = _account_dir(hermes_home)
+        self._cache: Dict[str, Dict[str, Any]] = {}
+
+    def _path(self, account_id: str) -> Path:
+        return self._root / f"{account_id}.reply-budget.json"
+
+    def _key(self, account_id: str, user_id: str) -> str:
+        return f"{account_id}:{user_id}"
+
+    def restore(self, account_id: str) -> None:
+        path = self._path(account_id)
+        if not path.exists():
+            return
+        try:
+            data = json.loads(path.read_text(encoding="utf-8"))
+        except Exception as exc:
+            logger.warning(
+                "weixin: failed to restore reply budget for %s: %s",
+                _safe_id(account_id),
+                exc,
+            )
+            return
+        restored = 0
+        now = time.time()
+        for user_id, entry in data.items():
+            if not isinstance(entry, dict):
+                continue
+            token = entry.get("token")
+            if not isinstance(token, str):
+                continue
+            count = entry.get("count", 0)
+            updated_at = entry.get("updated_at", now)
+            generation = entry.get("generation", 1)
+            if not isinstance(count, (int, float)) or count < 0:
+                count = 0
+            if not isinstance(generation, (int, float)) or generation < 1:
+                generation = 1
+            self._cache[self._key(account_id, user_id)] = {
+                "token": token,
+                "count": int(count),
+                "updated_at": float(updated_at),
+                "generation": int(generation),
+            }
+            restored += 1
+        if restored:
+            logger.info(
+                "weixin: restored %d reply budget(s) for %s",
+                restored,
+                _safe_id(account_id),
+            )
+
+    def update_token(self, account_id: str, user_id: str, token: str) -> int:
+        key = self._key(account_id, user_id)
+        previous = self._cache.get(key) or {}
+        generation = int(previous.get("generation", 0) or 0) + 1
+        self._cache[key] = {
+            "token": token,
+            "count": 0,
+            "updated_at": time.time(),
+            "generation": generation,
+        }
+        self._persist(account_id)
+        return generation
+
+    def reconcile_from_context_tokens(
+        self,
+        account_id: str,
+        context_tokens: Dict[str, str],
+    ) -> int:
+        changed = 0
+        for user_id, token in context_tokens.items():
+            if not isinstance(token, str) or not token:
+                continue
+            key = self._key(account_id, user_id)
+            entry = self._cache.get(key)
+            if not entry or entry.get("token") != token:
+                previous_generation = int((entry or {}).get("generation", 0) or 0)
+                self._cache[key] = {
+                    "token": token,
+                    "count": 0,
+                    "updated_at": time.time(),
+                    "generation": previous_generation + 1,
+                }
+                changed += 1
+        if changed:
+            self._persist(account_id)
+            logger.info(
+                "weixin: reconciled %d context token budget(s) for %s",
+                changed,
+                _safe_id(account_id),
+            )
+        return changed
+
+    def items_for_account(self, account_id: str) -> Dict[str, Dict[str, Any]]:
+        prefix = f"{account_id}:"
+        return {
+            key[len(prefix) :]: dict(value)
+            for key, value in self._cache.items()
+            if key.startswith(prefix) and isinstance(value, dict)
+        }
+
+    def snapshot(self, account_id: str, user_id: str) -> Dict[str, Any]:
+        entry = self._cache.get(self._key(account_id, user_id))
+        if not entry:
+            return {
+                "token": "",
+                "count": 0,
+                "updated_at": 0.0,
+                "generation": 0,
+            }
+        return dict(entry)
+
+    def get_valid_token(self, account_id: str, user_id: str) -> Optional[str]:
+        entry = self._cache.get(self._key(account_id, user_id))
+        if not entry:
+            return None
+        if time.time() - float(entry.get("updated_at", 0.0)) >= self._TOKEN_TTL_SECONDS:
+            return None
+        token = entry.get("token")
+        return token if isinstance(token, str) and token else None
+
+    def get_count(self, account_id: str, user_id: str) -> int:
+        entry = self._cache.get(self._key(account_id, user_id))
+        return int(entry.get("count", 0) or 0) if entry else 0
+
+    def get_generation(self, account_id: str, user_id: str) -> int:
+        entry = self._cache.get(self._key(account_id, user_id))
+        return int(entry.get("generation", 0) or 0) if entry else 0
+
+    def next_count(self, account_id: str, user_id: str) -> int:
+        return self.get_count(account_id, user_id) + 1
+
+    def commit_count(self, account_id: str, user_id: str, count: int) -> int:
+        key = self._key(account_id, user_id)
+        entry = self._cache.get(key)
+        if not entry:
+            entry = {
+                "token": "",
+                "count": 0,
+                "updated_at": time.time(),
+                "generation": 1,
+            }
+            self._cache[key] = entry
+        entry["count"] = max(int(entry.get("count", 0) or 0), int(count))
+        entry["updated_at"] = time.time()
+        self._persist(account_id)
+        return int(entry["count"])
+
+    def commit_count_if_generation(
+        self,
+        account_id: str,
+        user_id: str,
+        expected_generation: int,
+        count: int,
+    ) -> bool:
+        key = self._key(account_id, user_id)
+        entry = self._cache.get(key)
+        if not entry:
+            return False
+        if int(entry.get("generation", 0) or 0) != int(expected_generation):
+            return False
+        entry["count"] = max(int(entry.get("count", 0) or 0), int(count))
+        entry["updated_at"] = time.time()
+        self._persist(account_id)
+        return True
+
+    def increment_and_get(self, account_id: str, user_id: str) -> int:
+        return self.commit_count(
+            account_id,
+            user_id,
+            self.next_count(account_id, user_id),
+        )
+
+    def remaining(self, account_id: str, user_id: str) -> int:
+        return max(
+            0,
+            self._MAX_BUBBLES_PER_TOKEN - self.get_count(account_id, user_id),
+        )
+
+    def is_exhausted(self, account_id: str, user_id: str) -> bool:
+        return (
+            self.get_count(account_id, user_id)
+            >= self._MAX_BUBBLES_PER_TOKEN
+        )
+
+    def _persist(self, account_id: str) -> None:
+        prefix = f"{account_id}:"
+        payload = {
+            key[len(prefix) :]: value
+            for key, value in self._cache.items()
+            if key.startswith(prefix)
+        }
+        try:
+            atomic_json_write(self._path(account_id), payload)
+        except Exception as exc:
+            logger.warning(
+                "weixin: failed to persist reply budget for %s: %s",
+                _safe_id(account_id),
+                exc,
+            )
+

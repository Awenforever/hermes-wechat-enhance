+class MessageSendQueue:
+    # WECHAT_ENHANCE_QUEUE_PEEK_COMMIT_V2
+    # WECHAT_ENHANCE_DELIVERY_ID_DEDUPE_V2
+    _Item = Dict[str, Any]
+    def __init__(self): self._queues: Dict[str, List[MessageSendQueue._Item]] = {}
+    def _key(self, account_id: str, chat_id: str) -> str: return f"{account_id}:{chat_id}"
+    def _dedupe_key(self, delivery_id: str, chunk_index: int) -> str: return f"{delivery_id}:{int(chunk_index)}"
+    def enqueue(self, account_id: str, user_id: str, content: str, chat_id: str, reply_to: Optional[str], metadata: Optional[Dict[str, Any]]) -> bool:
+        key=self._key(account_id,user_id); queue=self._queues.setdefault(key,[]); metadata_dict=dict(metadata or {})
+        delivery_id=str(metadata_dict.get("_delivery_id") or metadata_dict.get("delivery_id") or "").strip()
+        if not delivery_id: delivery_id=f"auto-{uuid.uuid4().hex}"; metadata_dict["_delivery_id"]=delivery_id
+        try: chunk_index=int(metadata_dict.get("_delivery_chunk_index",len(queue)))
+        except Exception: chunk_index=len(queue)
+        metadata_dict["_delivery_chunk_index"]=chunk_index; dedupe_key=self._dedupe_key(delivery_id,chunk_index)
+        if any(str(item.get("dedupe_key"))==dedupe_key for item in queue): return False
+        queue.append({"content":content,"chat_id":chat_id,"reply_to":reply_to,"metadata":metadata_dict,"delivery_id":delivery_id,"chunk_index":chunk_index,"dedupe_key":dedupe_key,"enqueued_at":time.time()}); return True
+    def peek(self, account_id: str, user_id: str) -> Optional[_Item]:
+        queue=self._queues.get(self._key(account_id,user_id)); return queue[0] if queue else None
+    def dequeue(self, account_id: str, user_id: str) -> Optional[_Item]:
+        key=self._key(account_id,user_id); queue=self._queues.get(key)
+        if not queue: return None
+        item=queue.pop(0)
+        if not queue: self._queues.pop(key,None)
+        return item
+    def has_pending(self, account_id: str, user_id: str) -> bool: return bool(self._queues.get(self._key(account_id,user_id)))
+    def pending_count(self, account_id: str, user_id: str) -> int:
+        queue=self._queues.get(self._key(account_id,user_id)); return len(queue) if queue else 0
 
 

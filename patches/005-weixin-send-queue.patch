+def _is_system_meta(metadata: Optional[Dict[str, Any]]) -> bool:
+    if not isinstance(metadata, dict):
+        return False
+    if metadata.get("is_system") is True:
+        return True
+    for key in ("actor", "source", "message_origin", "origin"):
+        value = str(metadata.get(key) or "").strip().lower()
+        if value in {"system", "gateway", "status", "command", "lifecycle"}:
+            return True
+    return False
+
+
+def _footer_model_name(metadata: Optional[Dict[str, Any]]) -> str:
+    footer_metadata = metadata if isinstance(metadata, dict) else {}
+    if _is_system_meta(footer_metadata):
+        return "hermes"
+    return str(
+        os.environ.get("HERMES_WECHAT_FOOTER_MODEL_NAME")
+        or footer_metadata.get("model_name")
+        or footer_metadata.get("resolved_model")
+        or footer_metadata.get("routed_model")
+        or footer_metadata.get("model")
+        or "hermes"
+    ).strip() or "hermes"
+

+class ReplyBudgetStore:
+    """Persistent token-count budget per (account, user).
+
+    HERMES_V017_WEIXIN_REPLY_BUDGET_AND_FOOTER_PARITY_V1
+    Ported from the v0.10 Weixin enhancement so each Weixin bubble gets a
+    stable badge and model footer, and queued replies can resume after /continue.
+    """
+
+    _TOKEN_TTL_SECONDS: float = 24 * 3600.0
+    _MAX_BUBBLES_PER_TOKEN: int = 10
+
+    def __init__(self, hermes_home: str):
+        self._root = _account_dir(hermes_home)
+        self._cache: Dict[str, Dict[str, Any]] = {}
+
+    def _path(self, account_id: str) -> Path:
+        return self._root / f"{account_id}.reply-budget.json"
+
+    def _key(self, account_id: str, user_id: str) -> str:
+        return f"{account_id}:{user_id}"
+
+    def restore(self, account_id: str) -> None:
+        path = self._path(account_id)
+        if not path.exists():
+            return
+        try:
+            data = json.loads(path.read_text(encoding="utf-8"))
+        except Exception as exc:
+            logger.warning("weixin: failed to restore reply budget for %s: %s", _safe_id(account_id), exc)
+            return
+        restored = 0
+        now = time.time()
+        for uid, entry in data.items():
+            if not isinstance(entry, dict):
+                continue
+            token = entry.get("token")
+            if not isinstance(token, str) or not token:
+                continue
+            count = entry.get("count", 0)
+            updated_at = entry.get("updated_at", now)
+            if not isinstance(count, (int, float)) or count < 0:
+                count = 0
+            self._cache[self._key(account_id, uid)] = {
+                "token": token,
+                "count": int(count),
+                "updated_at": float(updated_at),
+            }
+            restored += 1
+        if restored:
+            logger.info("weixin: restored %d reply budget(s) for %s", restored, _safe_id(account_id))
+
+    def update_token(self, account_id: str, user_id: str, token: str) -> None:
+        self._cache[self._key(account_id, user_id)] = {
+            "token": token,
+            "count": 0,
+            "updated_at": time.time(),
+        }
+        self._persist(account_id)
+
+    def get_valid_token(self, account_id: str, user_id: str) -> Optional[str]:
+        entry = self._cache.get(self._key(account_id, user_id))
+        if not entry:
+            return None
+        if time.time() - entry["updated_at"] >= self._TOKEN_TTL_SECONDS:
+            return None
+        return entry["token"]
+
+    def increment_and_get(self, account_id: str, user_id: str) -> int:
+        key = self._key(account_id, user_id)
+        entry = self._cache.get(key)
+        if not entry:
+            self._cache[key] = {"token": "", "count": 1, "updated_at": time.time()}
+        else:
+            entry["count"] = entry.get("count", 0) + 1
+        self._persist(account_id)
+        return self._cache[key]["count"]
+
+    def get_count(self, account_id: str, user_id: str) -> int:
+        entry = self._cache.get(self._key(account_id, user_id))
+        if not entry:
+            return 0
+        return int(entry.get("count", 0) or 0)
+
+    def remaining(self, account_id: str, user_id: str) -> int:
+        return max(0, self._MAX_BUBBLES_PER_TOKEN - self.get_count(account_id, user_id))
+
+    def is_exhausted(self, account_id: str, user_id: str) -> bool:
+        return self.get_count(account_id, user_id) >= self._MAX_BUBBLES_PER_TOKEN
+
+    def _persist(self, account_id: str) -> None:
+        prefix = f"{account_id}:"
+        payload = {
+            key[len(prefix) :]: value
+            for key, value in self._cache.items()
+            if key.startswith(prefix)
+        }
+        try:
+            atomic_json_write(self._path(account_id), payload)
+        except Exception as exc:
+            logger.warning("weixin: failed to persist reply budget for %s: %s", _safe_id(account_id), exc)
+
+
+class MessageSendQueue:
+    """In-memory FIFO queue of pending outbound Weixin text chunks."""
+
+    _Item = Tuple[str, str, Optional[str], Optional[Dict[str, Any]]]
+
+    def __init__(self):
+        self._queues: Dict[str, List[MessageSendQueue._Item]] = {}
+
+    def _key(self, account_id: str, chat_id: str) -> str:
+        return f"{account_id}:{chat_id}"
+
+    def enqueue(
+        self,
+        account_id: str,
+        user_id: str,
+        content: str,
+        chat_id: str,
+        reply_to: Optional[str],
+        metadata: Optional[Dict[str, Any]],
+    ) -> None:
+        key = self._key(account_id, user_id)
+        self._queues.setdefault(key, []).append((content, chat_id, reply_to, metadata))
+
+    def dequeue(self, account_id: str, user_id: str) -> Optional[_Item]:
+        key = self._key(account_id, user_id)
+        queue = self._queues.get(key)
+        if not queue:
+            return None
+        return queue.pop(0)
+
+    def has_pending(self, account_id: str, user_id: str) -> bool:
+        key = self._key(account_id, user_id)
+        queue = self._queues.get(key)
+        return bool(queue)
+
+    def pending_count(self, account_id: str, user_id: str) -> int:
+        key = self._key(account_id, user_id)
+        queue = self._queues.get(key)
+        return len(queue) if queue else 0
+
